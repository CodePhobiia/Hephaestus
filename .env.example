# Hephaestus environment variables — copy to .env and fill in your keys.
# See docs/runbook.md for full configuration reference.

# --- LLM API Keys (at least one required) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
PERPLEXITY_API_KEY=

# --- Web Server ---
# API key for authenticating web requests (leave empty for open access — NOT recommended)
HEPH_API_KEY=
# Comma-separated allowed CORS origins
HEPH_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000
# Rate limit: max requests per minute
HEPH_RATE_LIMIT_RPM=10
# Max concurrent invention runs
HEPH_MAX_CONCURRENT=2
# Global spend cap in USD (resets on restart)
HEPH_SPEND_LIMIT_USD=20.0

# --- Transliminality Engine (Layer 2) ---
# Enable cross-domain structural synthesis
HEPHAESTUS_TRANSLIMINALITY_ENABLED=false

# --- Database ---
# Postgres connection URL (optional — defaults to SQLite)
HEPHAESTUS_DATABASE_URL=

# --- Testing ---
# Set to "1" to skip network-dependent tests in CI
HEPHAESTUS_OFFLINE_CI=
